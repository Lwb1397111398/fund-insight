# ============================================
# Fund Insight - 环境配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# --------------------------------------------
# LLM API 配置（必填）
# --------------------------------------------
# API Key - 从服务商获取
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# API 基础 URL
# 可选值：
#   - https://api.deepseek.com/v1 (DeepSeek)
#   - https://api.siliconflow.cn/v1 (硅基流动)
#   - https://api.openai.com/v1 (OpenAI)
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 模型名称
# 可选值：
#   - deepseek-chat (DeepSeek)
#   - deepseek-ai/DeepSeek-V3.2 (硅基流动 - 付费)
#   - Qwen/Qwen2.5-7B-Instruct (硅基流动 - 免费)
#   - gpt-4 (OpenAI)
LLM_MODEL=deepseek-ai/DeepSeek-V3.2

# 轻量级模型（用于简单任务，降低消耗）
# 硅基流动免费模型推荐：
#   - Qwen/Qwen2.5-7B-Instruct
#   - THUDM/glm-4-9b-chat
#   - 01-ai/Yi-1.5-9B-Chat-16K
LLM_LIGHT_MODEL=Qwen/Qwen2.5-7B-Instruct

# 模型选择策略
#   - auto: 自动选择（推荐，默认）
#   - high_quality: 所有任务使用主模型
#   - light: 所有任务使用轻量级模型
LLM_STRATEGY=auto

# LLM 提供商
#   - siliconflow: 硅基流动（默认）
#   - volcengine: 火山引擎
LLM_PROVIDER=siliconflow

# --------------------------------------------
# 火山引擎配置（LLM_PROVIDER=volcengine 时使用）
# --------------------------------------------
# 火山引擎 API Key
VOLCENGINE_API_KEY=

# 火山引擎 API Base URL
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎主力模型（用于核心分析任务）
VOLCENGINE_MODEL=doubao-seed-2-0-pro-260215

# 火山引擎辅助模型（用于简单任务，降低消耗）
VOLCENGINE_LIGHT_MODEL=doubao-seed-2-0-lite-260215

# --------------------------------------------
# 服务器配置
# --------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8002

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:8002

# --------------------------------------------
# 数据库配置（可选）
# --------------------------------------------
# 数据库连接 URL（PostgreSQL，用于云端部署）
# 格式：postgresql://user:password@host:port/dbname
# 未设置时使用本地 SQLite 数据库
# DATABASE_URL=postgresql://user:password@host:port/dbname

# --------------------------------------------
# 爬虫模块配置（可选）
# --------------------------------------------
# 是否启用爬虫模块（默认关闭）
# 可选值：true / false
CRAWLER_ENABLED=false

# 爬虫请求间隔（秒）- 避免请求过于频繁被封
CRAWLER_REQUEST_DELAY=2.0

# 每基金最多抓取帖子数
MAX_POSTS_PER_FUND=10

# 请求超时时间（秒）
CRAWLER_TIMEOUT=10

# --------------------------------------------
# 基金 API 配置（可选）
# --------------------------------------------
# 基金 API 请求超时时间（秒）
FUND_API_TIMEOUT=10

# 基金 API 最大重试次数
FUND_API_MAX_RETRIES=3

# --------------------------------------------
# 安全配置（可选）
# --------------------------------------------
# API 访问密码（所有 /api/ 请求需携带此密码）
# 未设置时使用默认密码
ACCESS_PASSWORD=your_access_password_here

# --------------------------------------------
# 熔断器配置（可选）
# --------------------------------------------
# 连续失败次数阈值，超过后触发熔断
CIRCUIT_BREAKER_THRESHOLD=5

# 熔断恢复时间（秒）
CIRCUIT_BREAKER_RECOVERY=60

# --------------------------------------------
# 缓存配置（可选）
# --------------------------------------------
# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存有效期（秒）
CACHE_TTL=3600

# --------------------------------------------
# 重试配置（可选）
# --------------------------------------------
# 最大重试次数
RETRY_MAX_COUNT=3

# 重试基础延迟（秒），实际延迟为 base * 2^attempt
RETRY_BASE_DELAY=1.0

# --------------------------------------------
# 预测验证配置（可选）
# --------------------------------------------
# 短期预测（1-3天）震荡阈值（%）
VERIFY_FLAT_THRESHOLD_SHORT=0.5

# 中期预测（1-3周）震荡阈值（%）
VERIFY_FLAT_THRESHOLD_MEDIUM=1.0

# 长期预测（1-3月）震荡阈值（%）
VERIFY_FLAT_THRESHOLD_LONG=2.0

# 最少数据点数（低于此值不验证）
VERIFY_MIN_DATA_POINTS=2

# 过程验证阈值（%）
VERIFY_PROCESS_THRESHOLD=0.5
